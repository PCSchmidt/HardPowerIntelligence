# Hard Power Intelligence — Environment Variables
#
# Copy this file to .env and fill in real values before running any service.
# .env is gitignored. This file (.env.example) is committed and documents every
# variable the project needs. Keep it in sync when adding new variables.
#
# Service key:
#   [api]    = hpi-api (FastAPI)
#   [worker] = hpi-worker (procrastinate)
#   [web]    = Next.js (Vercel)
#   [all]    = used by more than one service

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co                  # [all]

# Service role key (never expose to browser) — Project Settings → API Keys
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # [api] [worker]

# JWT secret — Project Settings → JWT Keys
SUPABASE_JWT_SECRET=your-jwt-secret-from-jwt-keys-page              # [api]

# Anon/public key — safe to expose in browser — Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co       # [web]
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... # [web]

# Direct asyncpg connection string (for engine/worker direct DB access)
# Get from dashboard → Connect button → Direct connection URI
# IMPORTANT: URL-encode special chars in password: @ → %40, ! → %21, # → %23
# Example: postgresql+asyncpg://postgres:REDACTED@db.ref.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:your-url-encoded-password@db.your-project-ref.supabase.co:5432/postgres # [api] [worker]

# ─── LLM — OpenRouter (all non-Anthropic models) ─────────────────────────────

OPENROUTER_API_KEY=sk-or-v1-...                                     # [worker]

# Model role assignments (D006) — change these to swap models without code changes
# Verify current model IDs at https://openrouter.ai/models before setting
LLM_MODEL_EXTRACTION=openrouter/deepseek/deepseek-v4-flash          # [worker]
LLM_MODEL_DISAMBIGUATION=openrouter/deepseek/deepseek-v4-flash      # [worker]
LLM_MODEL_SYNTHESIS=openrouter/deepseek/deepseek-v4-pro             # [worker]
LLM_MODEL_EVAL=openrouter/qwen/qwen3.7-max                          # [worker]
LLM_MODEL_SYNTHESIS_FALLBACK=openrouter/qwen/qwen3.7-max            # [worker]

# ─── LLM — Anthropic (last-resort fallback only, D006) ───────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...                                   # [worker]
LLM_MODEL_FALLBACK_LAST_RESORT=claude-sonnet-4-6                    # [worker]

# ─── LLM budget guards ────────────────────────────────────────────────────────

LLM_DAILY_BUDGET_USD=5.00                                            # [worker]
LLM_MONTHLY_BUDGET_USD=50.00                                         # [worker]

# ─── Embeddings — OpenAI (D026) ──────────────────────────────────────────────

OPENAI_API_KEY=sk-proj-...                                           # [worker]
EMBEDDING_MODEL=text-embedding-3-small                               # [worker]
EMBEDDING_DIMENSIONS=1536                                            # [worker]

# ─── Stripe ──────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_...                                        # [api]
STRIPE_PUBLISHABLE_KEY=pk_test_...                                   # [api] [web]
STRIPE_WEBHOOK_SECRET=whsec_...                                      # [api]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...                       # [web]

# ─── Observability ───────────────────────────────────────────────────────────

# Sentry DSN — create separate projects for api/worker and web if desired
SENTRY_DSN=https://key@oXXXXX.ingest.sentry.io/project-id           # [api] [worker]
SENTRY_DSN_WEB=https://key@oXXXXX.ingest.sentry.io/project-id-web   # [web]

# PostHog — web product analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...                                      # [web]
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com                     # [web]

# ─── Email ───────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_...                                                 # [api]
RESEND_FROM_EMAIL=noreply@hardpowerintel.com                         # [api]

# ─── FastAPI internal URL (Next.js server components → FastAPI) ──────────────

# Local dev: http://localhost:8000 | Production: https://hpi-api.fly.dev
FASTAPI_INTERNAL_URL=http://localhost:8000                           # [web]

# ─── Brief generation schedule (D014) ────────────────────────────────────────

# Cron expression used in worker/tasks.py @app.periodic decorators (UTC)
# 5:30am ET = 10:30 UTC in winter; 9:30 UTC in summer (ET/EDT) — adjust seasonally
BRIEF_GENERATION_CRON_UTC=30 10 * * *                                # [worker]
DATA_READINESS_CUTOFF_HOUR_UTC=10                                    # [worker]

# ─── Entity resolution thresholds (D027) ─────────────────────────────────────

ENTITY_RESOLUTION_HIGH_THRESHOLD=0.92                                # [worker]
ENTITY_RESOLUTION_MEDIUM_THRESHOLD=0.70                              # [worker]
ENTITY_RESOLUTION_LOW_THRESHOLD=0.55                                 # [worker]

# ─── Eval gate (D016) ────────────────────────────────────────────────────────

BRIEF_FAITHFULNESS_THRESHOLD=0.95                                    # [worker]

# ─── Materiality scoring (D030) ──────────────────────────────────────────────

MATERIALITY_THRESHOLD=0.35                                           # [worker]

# JSON object: source_id → authority weight (0.0–1.0)
SOURCE_WEIGHTS={"usaspending": 0.9, "dod_contracts": 0.85, "edgar": 0.85, "sam_gov": 0.8, "congress_gov": 0.8, "fred": 0.7, "gdelt": 0.5} # [worker]

# JSON object: entity_type → importance weight (0.0–1.0)
ENTITY_IMPORTANCE={"company": 1.0, "program": 0.85, "person": 0.7, "gov_agency": 0.75, "institution": 0.6, "sector": 0.5} # [worker]

# ─── RAG retrieval (D031) ────────────────────────────────────────────────────

RAG_PASSAGE_TOP_K=20                                                 # [worker]
RAG_GRAPH_EDGE_LIMIT=50                                              # [worker]

# ─── Worker ──────────────────────────────────────────────────────────────────

WORKER_CONCURRENCY=5                                                 # [worker]
WORKER_HEALTH_CHECK_PORT=8001                                        # [worker]

# ─── Data source API keys ─────────────────────────────────────────────────────

# SAM.gov — register free API key at https://sam.gov/profile (takes 2–3 days to activate)
SAM_GOV_API_KEY=your-sam-gov-api-key                                 # [worker]

# Financial Modeling Prep (~$19/mo) — https://financialmodelingprep.com/developer
FMP_API_KEY=your-fmp-api-key                                         # [worker]

# Finnhub (free tier) — https://finnhub.io
FINNHUB_API_KEY=your-finnhub-api-key                                 # [worker]

# EDGAR — no API key needed; User-Agent required (SEC policy)
EDGAR_USER_AGENT=hardpowerintelligence@gmail.com

# ─── Deployment ──────────────────────────────────────────────────────────────

# Fly.io — set via `fly secrets set` in CI/CD; listed here for documentation only
FLY_API_TOKEN=FlyV1 ...                                              # [deploy]

# Vercel — set in Vercel dashboard environment variables
VERCEL_TOKEN=...                                                     # [deploy]
